VITE_LOCALE=es-AR
VITE_LLM_PROVIDER=gemini
VITE_GEMINI_API_KEY=your_api_key_here
# VITE_LLM_PROVIDER=groq
# VITE_GROQ_API_KEY=your_groq_api_key_here

# Or use OpenRouter (many models: Claude, Gemini, Llama, etc.)
# VITE_LLM_PROVIDER=openrouter
# VITE_OPENROUTER_API_KEY=your_api_key_here
# VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Or use DeepInfra (low-cost inference, prompt cache for game rules)
# VITE_LLM_PROVIDER=deepinfra
# VITE_DEEPINFRA_API_KEY=your_deepinfra_api_key
# VITE_DEEPINFRA_MODEL=Qwen/Qwen2.5-72B-Instruct
# Examples: meta-llama/Llama-3.3-70B-Instruct-Turbo, zai-org/GLM-4.7-Flash, Qwen/Qwen3-235B-A22B-Instruct-2507

# Local dev (no API costs, use lightweight model)
# VITE_LLM_PROVIDER=ollama
# VITE_OLLAMA_MODEL=llama3.2:1b
